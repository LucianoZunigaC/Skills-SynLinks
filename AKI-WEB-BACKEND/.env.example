# Database
# SQLAlchemy connection string used by the application
SQLALCHEMY_DATABASE_URI=mssql+aioodbc://user:pass@server/db?driver=ODBC+Driver+17+for+SQL+Server
# Log all SQL statements (enable only in development)
SQLALCHEMY_ECHO=false

# Security
SECRET_KEY=your-super-secret-key-here-minimum-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your-azure-connection-string
PACKAGE_UPLOADS_CONTAINER_NAME=package-uploads

# API Configuration
API_DEBUG=False
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# OpenTelemetry SQLAlchemy instrumentation (optional)
# Enable sqlcommenter to append contextual tags to SQL queries
OTEL_SQLALCHEMY_ENABLE_COMMENTER=true
# Append sqlcommenter tags to db.statement span attribute (use carefully due to cardinality)
OTEL_SQLALCHEMY_ENABLE_ATTRIBUTE_COMMENTER=false
# Configure sqlcommenter tags
OTEL_SQLALCHEMY_COMMENTER_DB_DRIVER=true
OTEL_SQLALCHEMY_COMMENTER_DB_FRAMEWORK=true
OTEL_SQLALCHEMY_COMMENTER_OTEL_VALUES=true